# =============================================================================
# VARIÁVEIS DE AMBIENTE — SISTEMA DE OCORRÊNCIAS
# =============================================================================
# Copie este arquivo para ".env" na raiz do projeto e preencha com as
# credenciais do seu projeto Supabase.
#
#   cp .env.example .env
#
# Onde encontrar no Supabase:
#   Painel do projeto → Project Settings → API
#     - Project URL  → EXPO_PUBLIC_SUPABASE_URL
#     - anon public  → EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# IMPORTANTE: nunca versione o arquivo ".env" real (já está no .gitignore).
# Use apenas a chave "anon" (pública). NÃO use a chave "service_role" no app.
# =============================================================================

EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui
