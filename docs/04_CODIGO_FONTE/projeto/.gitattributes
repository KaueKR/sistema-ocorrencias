# Normaliza todas as quebras de linha para LF no repositório
* text=auto eol=lf

# Arquivos que devem sempre ser LF
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Arquivos binários — não converter
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary